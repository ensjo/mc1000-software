1  CLEAR 512,16204: REM RESERVA RAM ALTA PARA ROTINA EM CODIGO DE MAQUINA
2  GOTO 100: REM PROGRAMA PRINCIPAL
3  REM *** ROTINAS UTILITARIAS MC-1000
4  REM ** LOCATE H,V : POSICIONA CURSOR
5  POKE 910,0: PRINT AT$; CHR$ (V); CHR$ (H + 32);: POKE 910,H AND 31: RETURN 
6  REM ** K$=INKEY$ : LE TECLA
7 K$ =  USR (0) INPUT : RETURN 
8  REM ** B = VPEEK(E) : LE BYTE DA VRAM
9  CALL 51334:B =  PEEK (VR + E): CALL 51321: RETURN : REM ATIVA VRAM; LE BYTE; DESATIVA VRAM
10  REM ** VPOKE E,B : ESCREVE BYTE NA VRAM
11  CALL 51334: POKE VR + E,B: CALL 51321: RETURN : REM ATIVA VRAM; ESCREVE BYTE; DESATIVA VRAM
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 60000: REM INICIALIZA MC-1000
120  GOSUB 9000: REM INICIALIZA PROGRAMA
130  REM LACO PRINCIPAL
140  GOSUB 2000: REM INICIALIZA JOGO
150  GOSUB 1000: REM LACO DE JOGO
160  GOSUB 3000: REM FIM DE JOGO
170  GOTO 140: REM NOVO JOGO
1000  REM ** LACO DE JOGO
1010 E = P:B = BJ: GOSUB 11: REM EXIBE JOGADOR
1020 LP = P: REM ULTIMA POSICAO
1100  REM AGUARDA COMANDO
1110 T = T + 1: REM INCREMENTA TEMPO
1120  GOSUB 7: REM LE TECLA
1130  IF K$ = "" THEN 1110
1140  IF K$ = "A" THEN P = P - 1: REM ESQUERDA
1150  IF K$ = "D" THEN P = P + 1: REM DIREITA
1160  IF K$ = "W" THEN P = P - 32: REM CIMA
1170  IF K$ = "S" THEN P = P + 32: REM BAIXO
1180  IF P = LP THEN 1110
1200  REM VERIFICA MOVIMENTO POSSIVEL
1210 E = P: GOSUB 9: IF B = BP THEN P = LP: GOTO 1110: REM NAO MOVE SE ENCONTROU PAREDE
1300  REM PROCESSA MOVIMENTO
1310 E = P: GOSUB 9: IF B = BD THEN D = D + 1: REM COLETA PONTO
1320 E = LP:B = BE: GOSUB 11: REM APAGA ULTIMA POSICAO
1330  IF D <  > DD THEN 1010: REM AINDA HA PONTOS A COLETAR
1340 E = P:B = BE: GOSUB 11: REM APAGA JOGADOR
1350  RETURN 
2000  REM ** INICIALIZA JOGO
2010 P = P0: REM POSICAO DO JOGADOR
2020 D = 0: REM PONTOS COLETADOS
2030 T = 0: REM TEMPO
2100  REM DESENHA LABIRINTO
2110  FOR N = 0 TO 15
2120 H = MX:V = N: GOSUB 5: PRINT A$(N);
2130  NEXT N
2140  RETURN 
3000  REM ** FIM DE JOGO
3010  REM CALCULA PLACAR
3020 TI =  INT (T / 10): REM TEMPO PARA EXIBICAO
3030  IF FA > TI THEN FA = TI: REM ATUALIZA MELHOR TEMPO
3100  REM EXIBE PLACAR
3110 H = 25:V = 0: GOSUB 5: PRINT "TEMPO:";
3120 H = 25:V = 1: GOSUB 5: PRINT TI;
3130 H = 25:V = 4: GOSUB 5: PRINT "MELHOR";
3131 H = 25:V = 5: GOSUB 5: PRINT "TEMPO:";
3140 H = 25:V = 6: GOSUB 5: PRINT FA;
3200  REM JOGAR DE NOVO
3210 H = 25:V = 9: GOSUB 5: PRINT "PRESSI-";
3211 H = 25:V = 10: GOSUB 5: PRINT "  ONE";
3212 H = 25:V = 11: GOSUB 5: PRINT "<ENTER>";
3213 H = 25:V = 12: GOSUB 5: PRINT " PARA";
3214 H = 25:V = 13: GOSUB 5: PRINT "COMECAR";
3215 H = 25:V = 14: GOSUB 5: PRINT "DE NOVO";
3220  GOSUB 7: REM LE TECLA
3230  IF K$ <  >  CHR$ (13) THEN 3220
3240 H = 25:V = 9: GOSUB 5: PRINT "       ";
3241 H = 25:V = 10: GOSUB 5: PRINT "       ";
3242 H = 25:V = 11: GOSUB 5: PRINT "       ";
3243 H = 25:V = 12: GOSUB 5: PRINT "       ";
3244 H = 25:V = 13: GOSUB 5: PRINT "       ";
3245 H = 25:V = 14: GOSUB 5: PRINT "       ";
3250  RETURN 
9000  REM *** INICIALIZA PROGRAMA
9010  REM CONSTANTES
9020 MX = 6: REM MARGEM ESQUERDA DO LABIRINTO
9030 P0 = 0: REM POSICAO INICIAL DO JOGADOR (A DEFINIR)
9040 DD = 0: REM PONTOS A COLETAR (A DEFINIR)
9050 BP =  ASC (" ") + 128: REM BYTE DA PAREDE (ESPACO INVERTIDO)
9060 BE =  ASC (" "): REM BYTE DE ESPACO VAZIO
9070 BD =  ASC ("."): REM BYTE DE PONTO
9080 BJ =  ASC ("*"): REM BYTE DO JOGADOR
9090  GOSUB 9200: REM INICIALIZA LABIRINTO
9100  REM VARIAVEIS
9110 FA = 999999: REM MELHOR TEMPO
9120  RETURN 
9200  REM ** INICIALIZA LABIRINTO
9210  DIM A$(15): REM LABIRINTO
9220  RESTORE 9500
9230  FOR N = 0 TO 15
9240  READ A$
9250  FOR M = 1 TO  LEN (A$)
9260 C$ =  MID$ (A$,M,1)
9270  IF C$ = "A" THEN C$ =  CHR$ (BP): GOTO 9310: REM PAREDE
9280  IF C$ = "*" THEN P0 = N * 32 + MX + (M - 1): GOTO 9310: REM POSICAO INICIAL DO JOGADOR
9290  IF C$ = "." THEN DD = DD + 1: GOTO 9310: REM PONTO
9300  PRINT "CARACTER INVALIDO!": END 
9310 A$(N) = A$(N) + C$
9320  NEXT M,N
9330  RETURN 
