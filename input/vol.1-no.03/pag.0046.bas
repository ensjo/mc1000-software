1  CLEAR 512,16204: REM RESERVA RAM ALTA PARA ROTINA EM CODIGO DE MAQUINA
2  GOTO 100: REM INICIO
3  REM === ROTINAS MC-1000 ===
4  REM LOCATE H,V # POSICIONA CURSOR
5  POKE 910,0: PRINT AT$; CHR$ (V); CHR$ (H + 32);: POKE 910,H AND 31: RETURN 
6  REM K$ = INKEY$ # LE TECLA
7 K$ =  USR (0) INPUT : RETURN 
8  REM B = VPEEK(E) # LE BYTE DA VRAM
9  CALL 51334:B =  PEEK (VR + E): CALL 51321: RETURN 
10  REM VPOKE E,B # ESCREVE BYTE NA VRAM
11  CALL 51334: POKE VR + E,B: CALL 51321: RETURN 
100  REM === INICIO ===
110 GOSUB 60000: REM INICIALIZA MC-1000
120  GOSUB 700: REM INICIALIZA PROGRAMA
130  GOSUB 400: REM INICIALIZA JOGO
140  GOSUB 200: REM LACO PRINCIPAL
150  GOSUB 500: REM FIM DE JOGO
160  GOTO 130
200  REM LACO PRINCIPAL
210 E = P:B =  ASC ("*"): GOSUB 10: REM EXIBE JOGADOR
220 LP = P: REM POSICAO ANTERIOR
230 T = T + 1: REM INCREMENTA TEMPO
240  GOSUB 6: REM LE TECLA
250  IF K$ = "" THEN 230
260  IF K$ = "A" THEN E = P - 1: GOSUB 8: IF B < 128 THEN P = P - 1
270  IF K$ = "D" THEN E = P + 1: GOSUB 8: IF B < 128 THEN P = P + 1
280  IF K$ = "W" THEN E = P - 32: GOSUB 8: IF B < 128 THEN P = P - 32
290  IF K$ = "S" THEN E = P + 32: GOSUB 8: IF B < 128 THEN P = P + 32
300  IF P = LP THEN 230
310 E = P: GOSUB 8: IF B =  ASC (".") THEN D = D + 1: REM COLETA PONTO
320 E = LP:B =  ASC (" "): GOSUB 10: REM APAGA POSICAO ANTERIOR
330  IF D <  > DD THEN 210: REM AINDA HA PONTOS A COLETAR
340 E = P:B =  ASC (" "): GOSUB 10: REM APAGA JOGADOR
350  RETURN 
400  REM INICIALIZA JOGO
410 P = P0: REM POSICAO DO JOGADOR
420 D = 0: REM PONTOS COLETADOS
430 T = 0: REM TEMPO
450  REM DESENHA LABIRINTO
460  FOR N = 0 TO 15
470 H = MX:V = N: GOSUB 4: PRINT A$(N);
480  NEXT N
490  RETURN 
500  REM FIM DE JOGO
510 TI =  INT (T / 10): REM TEMPO EM SEGUNDOS (APROX.)
520 H = 25:V = 0: GOSUB 4: PRINT "TEMPO:";
530 H = 25:V = 1: GOSUB 4: PRINT TI;
540  IF FA > TI THEN FA = TI: REM ATUALIZA MELHOR TEMPO
550 H = 25:V = 4: GOSUB 4: PRINT "MELHOR";
551 H = 25:V = 5: GOSUB 4: PRINT "TEMPO:";
560 H = 25:V = 6: GOSUB 4: PRINT FA;
570 H = 25:V = 9: GOSUB 4: PRINT "PRESSI-";
571 H = 25:V = 10: GOSUB 4: PRINT "  ONE";
572 H = 25:V = 11: GOSUB 4: PRINT "<ENTER>";
573 H = 25:V = 12: GOSUB 4: PRINT " PARA";
574 H = 25:V = 13: GOSUB 4: PRINT "COMECAR";
575 H = 25:V = 14: GOSUB 4: PRINT "DE NOVO";
580  GOSUB 6: REM LE TECLA
585  IF K$ <  >  CHR$ (13) THEN 580
600 H = 25:V = 9: GOSUB 4: PRINT "       ";
601 H = 25:V = 10: GOSUB 4: PRINT "       ";
602 H = 25:V = 11: GOSUB 4: PRINT "       ";
603 H = 25:V = 12: GOSUB 4: PRINT "       ";
604 H = 25:V = 13: GOSUB 4: PRINT "       ";
605 H = 25:V = 14: GOSUB 4: PRINT "       ";
610  RETURN 
700  REM INICIALIZA PROGRAMA
710 FA = 999999: REM MELHOR TEMPO
720 MX = 6: REM MARGEM ESQUERDA DO LABIRINTO
730 P0 = 0: REM POSICAO INICIAL DO JOGADOR
740 DD = 0: REM PONTOS A COLETAR
750  REM INICIALIZA LABIRINTO
760  DIM A$(15): REM LABIRINTO
770  RESTORE 900
780  FOR N = 0 TO 15
790  READ A$
800  FOR M = 1 TO  LEN (A$)
810 C$ =  MID$ (A$,M,1)
820  IF C$ = "A" THEN C$ =  CHR$ (32 + 128): GOTO 860: REM PAREDE (ESPACO INVERTIDO)
830  IF C$ = "*" THEN P0 = N * 32 + MX + (M - 1): GOTO 860: REM POSICAO INICIAL DO JOGADOR
840  IF C$ = "." THEN DD = DD + 1: GOTO 860
850  PRINT "CARACTER INVALIDO!": END 
860 A$(N) = A$(N) + C$
870  NEXT M,N
880  RETURN 
