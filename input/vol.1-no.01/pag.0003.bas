1  CLEAR 512,16127: REM RESERVA RAM ALTA PARA ROTINA Z80
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 60000: REM INICIALIZA MC-1000
120  REM LOOP PRINCIPAL - COPIA BLOCOS ALEATORIOS DA ROM PARA VRAM
130 A =  USR (ROM +  RND (1) * 11000)
140  GOTO 130
60000  REM *** INICIALIZA MC-1000
60010  REM CONSTANTES
60030 ROM = 49152: REM ENDERECO DA ROM ($C000)
60040  REM CONFIGURA VIDEO
60050  TEXT : HOME 
60060  POKE 245,65: REM MODO SEMIGRAPHICS 4
60100  REM CARREGA DADOS EM MEMORIA
60110  RESTORE 60200
60120  READ E: REM ENDERECO DE INICIO DO BLOCO
60130  READ B: IF B >  = 0 THEN  POKE E,B:E = E + 1: GOTO 60130
60140  ON  ABS (B) GOTO 60120,60150: PRINT "ERRO:";B;"EM";E: END 
60150  RETURN 
60200  REM DADOS A CARREGAR NA MEMORIA
60210  REM DEFUSR=16128
60220  DATA 771        : REM ORG $0303
60230  DATA 195,0,63   : REM JP $3F00
60240  DATA -1: REM FIM DE BLOCO
60300  REM ROTINA USR
60310  DATA 16128      : REM ORG $3F00
60320  DATA 205,134,200: REM CALL $C886  ;ATIVA VRAM
60330  DATA 205,240,222: REM CALL $DEF0  ;DE=ARGUMENTO DE USR()
60340  DATA 235        : REM EX DE,HL    ;HL=ARGUMENTO DE USR()
60350  DATA 17,0,128   : REM LD DE,$8000 ;DE=INICIO DA VRAM
60360  DATA 1,0,2      : REM LD BC,$0200 ;BC=512 BYTES
60370  DATA 237,176    : REM LDIR        ;COPIA BYTES HL->DE
60380  DATA 205,121,200: REM CALL $C879  ;DESATIVA VRAM
60390  DATA 201        : REM RET
60400  DATA -2: REM FIM DE DADOS
