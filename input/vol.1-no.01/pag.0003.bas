120  REM LOOP PRINCIPAL - COPIA BLOCOS ALEATORIOS DA ROM PARA VRAM
130 A =  USR (ROM +  RND (1) * 11000)
140  GOTO 130
64000  REM *** INICIALIZA MC-1000
64010  REM CONSTANTES
64030 ROM = 49152: REM ENDERECO DA ROM ($C000)
64040  REM CONFIGURA VIDEO
64050  TEXT : HOME 
64060  POKE 245,65: REM MODO SEMIGRAPHICS 4
64100  REM CARREGA DADOS EM MEMORIA
64110  RESTORE 64200
64120  READ E: REM ENDERECO DE INICIO DO BLOCO
64130  READ B: IF B >  = 0 THEN  POKE E,B:E = E + 1: GOTO 64130
64140  ON  ABS (B) GOTO 64120,64150: PRINT "ERRO:";B;"EM";E: END 
64150  RETURN 
64200  REM DADOS A CARREGAR NA MEMORIA
