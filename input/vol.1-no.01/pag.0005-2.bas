1  GOTO 100: REM PROGRAMA PRINCIPAL
2  REM *** ROTINAS UTILITARIAS MC-1000
3  REM ** LOCATE H,V : POSICIONA CURSOR
4  POKE 910,0: PRINT AT$; CHR$ (V); CHR$ (H + 32);: POKE 910,H AND 31: RETURN 
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 60000: REM INICIALIZA MC-1000
120  REM LACO PRINCIPAL
130  FOR N = 0 TO 28: REM POSICAO HORIZONTAL DO INSETO
140  GOSUB 1000: REM DESENHA INSETO (QUADRO 1)
150  GOSUB 4000: REM PAUSA
160  GOSUB 3000: REM APAGA INSETO
170  GOSUB 2000: REM DESENHA INSETO (QUADRO 2)
180  GOSUB 4000: REM PAUSA
190  GOSUB 3000: REM APAGA INSETO
200  NEXT N
210  GOTO 130
1000  REM ** DESENHA INSETO (QUADRO 1)
1010 H = N:V = 6: GOSUB 4: PRINT ")))";
1020 H = N:V = 7: GOSUB 4: PRINT "000<";
1030 H = N:V = 8: GOSUB 4: PRINT ")))";
1040  RETURN 
2000  REM ** DESENHA INSETO (QUADRO 2)
2010 H = N:V = 6: GOSUB 4: PRINT "(((";
2020 H = N:V = 7: GOSUB 4: PRINT "000<";
2030 H = N:V = 8: GOSUB 4: PRINT "(((";
2040  RETURN 
3000  REM ** APAGA INSETO
3010 H = N:V = 6: GOSUB 4: PRINT "   ";
3020 H = N:V = 7: GOSUB 4: PRINT "    ";
3030 H = N:V = 8: GOSUB 4: PRINT "   ";
3040  RETURN 
4000  REM ** PAUSA
4010  FOR X = 1 TO 100: NEXT : RETURN 
60000  REM *** INICIALIZA MC-1000
60010  REM CONSTANTES
60020 AT$ =  CHR$ (27) + "=": REM ESCAPE P/ POSICIONAR CURSOR
60030  REM CONFIGURA VIDEO
60040  TEXT : HOME 
60050  POKE 247,202: POKE 248,192: POKE 249,202: POKE 250,192: CALL 52013: REM CURSOR INVISIVEL
60060  RETURN 
