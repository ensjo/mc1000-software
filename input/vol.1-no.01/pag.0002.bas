1  CLEAR 512,16127: REM RESERVA RAM ALTA PARA ROTINA EM CODIGO DE MAQUINA
2  GOTO 100: REM PROGRAMA PRINCIPAL
3  REM *** ROTINAS UTILITARIAS MC-1000
4  REM ** DESATIVA PISCAMENTO DO CURSOR
5  POKE 304,201: RETURN 
6  REM ** ATIVA VRAM
7  CALL 51334: RETURN 
8  REM ** DESATIVA VRAM
9  CALL 51321: RETURN 
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 64000: REM INICIALIZA MC-1000
120  GOSUB 1000: REM EXECUTA ROTINA EM BASIC
130  GOSUB 2000: REM EXECUTA ROTINA EM CODIGO DE MAQUINA
140  END 
1000  REM ** COPIA LIXO ROM->VRAM USANDO BASIC (LENTO)
1010  TEXT : HOME 
1020  PRINT "ISTO ESTA EM BASIC."
1030  FOR N = 1 TO 1000: NEXT : REM PAUSA
1040 V0 = VRAM + 32: REM ENDERECO DE INICIO DA SEGUNDA LINHA DE TEXTO NA VRAM
1050 V1 = VRAM + 512 - 1: REM ENDERECO DE FIM DA VRAM
1060 D = ROM - V0: REM DIFERENCA ROM<->VRAM
1070  GOSUB 5: REM DESATIVA PISCAMENTO DO CURSOR (EVITA DESATIVACAO DA VRAM)
1080  GOSUB 7: REM ATIVA VRAM
1090  FOR E = V0 TO V1
1100  POKE E, PEEK (E + D): REM COPIA BYTE DA ROM PARA A VRAM
1110  NEXT E
1120  GOSUB 9: REM DESATIVA VRAM
1130  FOR N = 1 TO 2000: NEXT : REM PAUSA
1140  RETURN 
2000  REM ** COPIA LIXO ROM->VRAM USANDO CODIGO DE MAQUINA (RAPIDO)
2010  HOME 
2020  PRINT "ISTO ESTA EM CODIGO DE MAQUINA."
2030  FOR N = 1 TO 1000: NEXT : REM PAUSA
2040  CALL 16128: REM EXECUTA ROTINA DE COPIA EM LINGUAGEM DE MAQUINA
2050  FOR N = 1 TO 2000: NEXT : REM PAUSA
2060  RETURN 
64000  REM *** INICIALIZA MC-1000
64010  REM CONSTANTES
64020 VRAM = 32768: REM ENDERECO DA VRAM
64030 ROM = 49152: REM ENDERECO DA ROM
64100  REM CARREGA ROTINA EM CODIGO DE MAQUINA
64110  RESTORE 64200
64120  READ E: REM LE ENDERECO INICIAL
64130  READ B: REM LE BYTE
64140  IF B =  - 1 THEN  RETURN 
64150  POKE E,B
64160 E = E + 1
64170  GOTO 64130
64200  REM DADOS DA ROTINA EM CODIGO DE MAQUINA
64210  DATA 16128      : REM ORG $3E00
64220  DATA 205,134,200: REM CALL $C886  ;ATIVA VRAM
64230  DATA 33,0,192   : REM LD HL,$C000 ;INICIO DA ROM
64240  DATA 17,32,128  : REM LD DE,$8020 ;SEGUNDA LINHA DA TELA
64250  DATA 1,224,1    : REM LD BC,$01E0 ;480 BYTES
64260  DATA 237,176    : REM LDIR        ;COPIA BYTES
64270  DATA 205,121,200: REM CALL $C879  ;DESATIVA VRAM
64280  DATA 201        : REM RET
64290  DATA -1
65500  REM *** CATALOGACAO
65501  REM REVISTA INPUT (BR)
65502  REM VOL.1,NO.1,PAG.2
65503  REM CODIGO DE MAQUINA 1
65504  REM "PROGRAMACAO EM CODIGO DE MAQUINA"
65505  REM VERSAO CCE MC-1000
