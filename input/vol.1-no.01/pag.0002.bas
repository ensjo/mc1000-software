1  CLEAR 512,16127: REM RESERVA RAM ALTA PARA ROTINA Z80
2  GOTO 100: REM PROGRAMA PRINCIPAL
3  REM *** ROTINAS UTILITARIAS MC-1000
4  REM ** DESATIVA PISCAMENTO DO CURSOR
5  POKE 304,201: RETURN 
6  REM ** ATIVA VRAM
7  CALL 51334: RETURN 
8  REM ** DESATIVA VRAM
9  CALL 51321: RETURN 
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 60000: REM INICIALIZA MC-1000
120  GOSUB 1000: REM DEMONSTRA VELOCIDADE DO BASIC INTERPRETADO (LENTO)
130  GOSUB 2000: REM DEMONSTRA VELOCIDADE DO CODIGO DE MAQUINA (RAPIDO)
140  END 
1000  REM ** DEMONSTRA VELOCIDADE DO BASIC INTERPRETADO
1010  TEXT : HOME 
1020  PRINT "ISTO ESTA EM BASIC."
1030  FOR N = 1 TO 1000: NEXT : REM PAUSA
1040 V0 = VRAM + 32: REM ENDERECO DE INICIO DA SEGUNDA LINHA DE TEXTO NA VRAM
1050 V1 = VRAM + 512 - 1: REM ENDERECO DE FIM DA VRAM DE TEXTO
1060 D = ROM - V0: REM DIFERENCA ROM<->VRAM
1070  GOSUB 5: REM DESATIVA PISCAMENTO DO CURSOR (EVITA DESATIVACAO DA VRAM)
1080  GOSUB 7: REM ATIVA VRAM
1090  FOR E = V0 TO V1: POKE E, PEEK (E + D): NEXT E: REM COPIA BYTES ROM->VRAM USANDO BASIC
1100  GOSUB 9: REM DESATIVA VRAM
1110  FOR N = 1 TO 2000: NEXT : REM PAUSA
1120  RETURN 
2000  REM ** DEMONSTRA VELOCIDADE DO CODIGO DE MAQUINA
2010  HOME 
2020  PRINT "ISTO ESTA EM CODIGO DE MAQUINA."
2030  FOR N = 1 TO 1000: NEXT : REM PAUSA
2040  CALL 16128: REM COPIA BYTES ROM->VRAM USANDO CODIGO DE MAQUINA
2050  FOR N = 1 TO 2000: NEXT : REM PAUSA
2060  RETURN 
60000  REM *** INICIALIZA MC-1000
60010  REM CONSTANTES
60020 VRAM = 32768: REM ENDERECO DA VRAM ($8000)
60030 ROM = 49152: REM ENDERECO DA ROM ($C000)
60100  REM CARREGA DADOS EM MEMORIA
60110  RESTORE 60200
60120  READ E: REM LE ENDERECO INICIAL
60130  READ B: REM LE BYTE
60140  IF B =  - 1 THEN  RETURN 
60150  POKE E,B
60160 E = E + 1
60170  GOTO 60130
60200  REM DADOS DA ROTINA EM CODIGO DE MAQUINA
60210  DATA 16128      : REM ORG $3F00
60220  DATA 205,134,200: REM CALL $C886  ;ATIVA VRAM
60230  DATA 33,0,192   : REM LD HL,$C000 ;HL=INICIO DA ROM
60240  DATA 17,32,128  : REM LD DE,$8020 ;DE=SEGUNDA LINHA DA TELA
60250  DATA 1,224,1    : REM LD BC,$01E0 ;BC=512-32=480 BYTES
60260  DATA 237,176    : REM LDIR        ;COPIA BYTES HL->DE
60270  DATA 205,121,200: REM CALL $C879  ;DESATIVA VRAM
60280  DATA 201        : REM RET
60290  DATA -1: REM FIM DE DADOS
65500  REM *** CATALOGACAO
65501  REM REVISTA INPUT (BR)
65502  REM VOL.1,NO.1,PAG.2
65503  REM CODIGO DE MAQUINA 1
65504  REM "PROGRAMACAO EM CODIGO DE MAQUINA"
65505  REM VERSAO CCE MC-1000
