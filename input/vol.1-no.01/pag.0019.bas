1  GOTO 100: REM PROGRAMA PRINCIPAL
2  REM *** ROTINAS UTILITARIAS MC-1000
3  REM ** DIRECIONA IMPRESSAO PARA IMPRESSORA
4  PR# 1: RETURN 
5  REM ** DIRECIONA IMPRESSAO PARA TELA
6  PR# 0: RETURN 
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 9000: REM INICIALIZA PROGRAMA
120  GOSUB 1000: REM IMPRIME CARTA
130  END 
1000  REM *** IMPRIME CARTA
1010  GOSUB 1860: REM SINALIZA INICIO DE LINHA
1020  GOSUB 1100: REM LE PROXIMA STRING
1030  IF C = L THEN  GOTO 1020: REM FIM DA STRING?
1040  GOSUB 1200: REM PROXIMO CARACTER
1050  IF C = 1 THEN  GOSUB 1300: REM TRATA PRIMEIRO CARACTER
1060  IF B$ = " " THEN  GOSUB 1400: REM TRATA ESPACO
1070  IF B$ <  > "" THEN  GOSUB 1500: REM IMPRIME CARACTER
1080  GOTO 1030
1100  REM ** PROXIMA STRING
1110  READ A$: REM LE STRING A IMPRIMIR
1120 L =  LEN (A$): REM COMPRIMENTO DA STRING
1130 C = 0: REM POSICAO DO CARACTER NA STRING
1140  RETURN 
1200  REM ** PROXIMO CARACTER
1210 D = D + 1: REM AVANCA POSICAO NA PAGINA
1220 C = C + 1: REM AVANCA POSICAO NA STRING
1230 B$ =  MID$ (A$,C,1): REM OBTEM CARACTER
1240  RETURN 
1300  REM ** TRATA PRIMEIRO CARACTER
1310  IF B$ = "=" THEN  GOSUB 5: END : REM FIM DA CARTA
1320  IF B$ = "#" THEN  GOSUB 1600: RETURN : REM ENDERECO
1330  IF B$ = "*" THEN  GOSUB 1700: RETURN : REM CENTRALIZA
1340  IF B$ = "&" THEN  GOSUB 1820: GOSUB 1930: RETURN : REM QUEBRA LINHA
1350  IF B$ = "$" THEN  GOSUB 1800: GOSUB 1930: RETURN : REM QUEBRA PARAGRAFO
1360  REM SEM SIMBOLO NO INICIO DA STRING
1370 B$ = " ":A$ = " " + A$:L = L + 1: REM INSERE ESPACO PARA CONTINUAR PARAGRAFO ANTERIOR
1380  RETURN 
1400  REM ** TRATA ESPACO (WORD WRAP)
1410  REM CALCULA TAMANHO DA PROXIMA PALAVRA
1420 CC = C + 1: REM POSICAO A EXAMINAR
1430 X = 1: REM TAMANHO DA PROXIMA PALAVRA
1440  IF CC <  > L THEN  IF  MID$ (A$,CC,1) <  > " " THEN CC = CC + 1:X = X + 1: GOTO 1440: REM CONTA CARACTERES ENQUANTO NAO ENCONTRAR FIM DA STRING OU ESPACO
1450  IF X >  = LL THEN  PRINT : GOSUB 6: PRINT "ERRO NO FORMATO - PALAVRA MUITO GRANDE": END 
1460  REM SE NAO HA ESPACO PARA PROXIMA PALAVRA, QUEBRAR LINHA
1470 SL = LL - D - 1: REM ESPACO RESTANTE NA LINHA APOS O ESPACO
1475  IF SL >  = X THEN  RETURN 
1480  GOSUB 1820: REM QUEBRA DE LINHA
1490  GOSUB 1930: REM SINALIZA SUPRESSAO DA IMPRESSAO DO CARACTER (ESPACO)
1495  RETURN 
1500  REM ** IMPRIME CARACTER
1510  PRINT B$;
1520  IF D > LL THEN  GOSUB 1860: REM SINALIZA INICIO DE LINHA
1530  RETURN 
1600  REM ** ENDERECO
1610  IF D > 1 THEN  PRINT 
1620  PRINT  SPC( TR); MID$ (A$,2): REM IMPRIME STRING COM MARGEM DE ENDERECO
1630  GOSUB 1860: REM SINALIZA INICIO DE LINHA
1640  GOSUB 1900: REM SINALIZA LEITURA DA PROXIMA STRING
1650  GOSUB 1930: REM SINALIZA SUPRESSAO DA IMPRESSAO DO CARACTER ("#")
1660  RETURN 
1700  REM ** CENTRALIZA
1710 TA = (LL - L) / 2 + T: REM CALCULA LARGURA DA MARGEM PARA CENTRALIZAR
1720  IF TA < T THEN  PRINT CR$;: GOSUB 6: PRINT "ERRO NO FORMATO - NAO POSSO CENTRALIZAR.": END 
1730  IF D > 1 THEN  PRINT 
1740  PRINT  SPC( TA); MID$ (A$,2): REM IMPRIME STRING COM MARGEM PARA CENTRALIZAR
1750  GOSUB 1860: REM SINALIZA INICIO DE LINHA
1760  GOSUB 1900: REM SINALIZA LEITURA DA PROXIMA STRING
1770  GOSUB 1930: REM SINALIZA SUPRESSAO DA IMPRESSAO DO CARACTER ("*")
1780  RETURN 
1800  REM ** QUEBRA PARAGRAFO
1810  PRINT 
1820  REM ** QUEBRA LINHA
1830  IF D > 1 THEN  PRINT 
1840  REM ** IMPRIME MARGEM
1850  PRINT  SPC( T);
1860  REM ** SINALIZA INICIO DE LINHA
1870 D = 0
1880  RETURN 
1900  REM ** SINALIZA LEITURA DA PROXIMA STRING
1910 C = L
1920  RETURN 
1930  REM ** SINALIZA SUPRESSAO DA IMPRESSAO DO CARACTER
1940 B$ = ""
1950  RETURN 
2000  REM ** TEXTO DA CARTA
2010  DATA "#MARIO DA SILVA"
2020  DATA "#RUA MEXICO, 1245"
2030  DATA "#13100 CAMPINAS, SP"
2040  DATA "# "
2050  DATA "$"
2060  DATA "$SR. ATHOS OLIVEIRA"
2070  DATA "&DIRETOR PRESIDENTE"
2080  DATA "&INDUSTRIA DE OLEOS OLEINA"
2090  DATA "&RUA DAS PALMEIRAS, 111"
2100  DATA "&01045 SAO PAULO, SP"
2110  DATA "$"
2120  DATA "$"
2130  DATA "PREZADO SR. OLIVEIRA:"
2140  DATA "$"
2150  DATA "*REF: PEDIDO DE COLOCACAO"
2160  DATA "$"
2170  DATA "$TENDO TOMADO CONHECIMENTO, ATRAVES DO SEU ANUNCIO PUBLICADO NO"
2180  DATA "ESTADO DE SAO PAULO, DE UMA COLOCACAO IMEDIATA PARA PROGRAMADOR"
2190  DATA "TRAINEE, GOSTARIA DE COMUNICAR A V.SA. QUE ESTOU INTERESSADO NO"
2200  DATA "CARGO OFERECIDO."
2210  DATA "$PARA TANTO, ENVIO EM ANEXO MEU 'CURRICULO VITAE' ATUALIZADO,"
2220  DATA "COM TODAS AS INFORMACOES RELEVANTES A MEU RESPEITO."
2230  DATA "$NO AGUARDO DE UMA COMUNICACAO FAVORAVEL DE SUA PARTE, TERMINO"
2240  DATA "$"
2250  DATA "$"
2260  DATA "ATENCIOSAMENTE"
2270  DATA "$"
2280  DATA "$"
2290  DATA "MARIO DA SILVA"
2300  DATA "="
9000  REM *** INICIALIZA PROGRAMA
9010  REM PARAMETROS DE EXECUCAO
9020 PL = 32: REM LARGURA TOTAL DA IMPRESSORA
9030 LL = 30: REM LARGURA DA CARTA
9040  ON 2 GOSUB 4,6: REM 1=IMPRIME NA IMPRESSORA; 2=IMPRIME NA TELA
9100  REM CONSTANTES
9110 LL = LL + 1
9120 T = (PL - LL) / 2: REM LARGURA DA MARGEM ESQUERDA
9130 TR = 0: REM LARGURA DA MARGEM ESQUERDA DE ENDERECO (A DEFINIR)
9200  REM CALCULA LARGURA DA MARGEM ESQUERDA DE ENDERECO
9210 BE = 0
9220  RESTORE 2000
9230  READ A$
9240 B$ =  LEFT$ (A$,1)
9250  IF B$ <  > "#" THEN 9290: REM CONSIDERA APENAS STRINGS DE ENDERECO
9260 LE =  LEN (A$) - 1: REM COMPRIMENTO DA LINHA DE ENDERECO SEM "#"
9270  IF LE > LL THEN  GOSUB 4: PRINT "ERRO NO FORMATO - ENDERECO MUITO LONGO PARA O TAMANHO DE LINHA ESCOLHIDO.": END 
9280  IF LE > BE THEN BE = LE: REM RETEM O MAIOR COMPRIMENTO
9290  IF B$ <  > "=" THEN 9230: REM REPETE ATE O FIM DA CARTA
9300  RESTORE 2000: REM RESETA PONTEIRO DE LEITURA
9310 TR = T + LL - BE: REM LARGURA DA MARGEM ESQUERDA DE ENDERECO
9320  RETURN 
