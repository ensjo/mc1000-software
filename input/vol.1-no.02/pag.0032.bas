1  CLEAR 512,16204: REM RESERVA RAM ALTA PARA ROTINA EM CODIGO DE MAQUINA
2  GOTO 100: REM PROGRAMA PRINCIPAL
3  REM *** ROTINAS UTILITARIAS MC-1000
4  REM ** LOCATE H,V : POSICIONA CURSOR
5  POKE 910,0: PRINT AT$; CHR$ (V); CHR$ (H + 32);: POKE 910,H AND 31: RETURN 
6  REM ** INKEY$ : LE TECLADO
7 A$ =  USR (0) INPUT : RETURN 
8  REM LIMPA TELA COM CURSOR INVISIVEL
9  TEXT : HOME : POKE 247,202: POKE 248,192: POKE 249,202: POKE 250,192: CALL 52013: RETURN 
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 64000: REM INICIALIZA MC-1000
120  GOSUB 9000: REM INICIALIZA PROGRAMA
130  REM LACO PRINCIPAL
140  GOSUB 1000: REM RODADA
150  GOTO 140
1000  REM ** RODADA
1010  GOSUB 8000: REM INICIALIZA RODADA
1020  REM LACO RODADA
1030 H = X:V = Y: GOSUB 5: PRINT B$;: REM EXIBE BASE
1040  GOSUB 7: IF A$ = "" THEN 1030: REM AGUARDA TECLA
1050  GOSUB 1100: REM PROCESSA TECLA
1060  IF  NOT AA THEN 1030: REM REPETE ENQUANTO ALVO NAO ATINGIDO
1070  RETURN 
1100  REM ** PROCESSA TECLA
1110  IF A$ = "A" AND X > 0 THEN X = X - 1: REM MOVE BASE A ESQUERDA
1120  IF A$ = "D" AND X < 27 THEN X = X + 1: REM MOVE BASE A DIREITA
1130  IF A$ = "." THEN  GOSUB 1200: REM TIRO
1140  RETURN 
1200  REM ** TIRO
1210  FOR M = Y - 1 TO 0 STEP  - 1
1220 H = X + 2:V = M: GOSUB 5: PRINT "^";: REM EXIBE PROJETIL
1230 H = X + 2:V = M + 1: GOSUB 5: PRINT " ";: REM APAGA PROJETIL ANTERIOR
1240  IF M = 2 AND X + 2 = A THEN AA =  - 1: RETURN : REM ACERTOU ALVO
1250  NEXT M
1260 H = X + 2:V = 0: GOSUB 5: PRINT " ";: REM APAGA ULTIMO PROJETIL
1270  RETURN 
8000  REM ** INICIALIZA RODADA
8010  REM VARIAVEIS
8020 X = 15:Y = 14: REM POSICAO DA NAVE
8030 A =  INT ( RND (1) * 28) + 2: REM POSICAO DO ALVO
8040 AA = 0: REM ALVO NAO ATINGIDO
8050  REM VIDEO
8060  GOSUB 8: REM LIMPA TELA
8070 H = A:V = 2: GOSUB 5: PRINT "*";: REM EXIBE ALVO
8080  RETURN 
9000  REM *** INICIALIZA PROGRAMA
9010  REM CONSTANTES
9020 B$ = " /^" +  CHR$ (92) + " ": REM DESENHO DA BASE
9030  RETURN 
64000  REM *** INICIALIZA MC-1000
64010  REM CONSTANTES
64020 AT$ =  CHR$ (27) + "=": REM ESCAPE P/ POSICIONAR CURSOR
64030  REM ROTINA EM LINGUAGEM DE MAQUINA
64040  GOSUB 64100: REM CARREGA DADOS EM MEMORIA
64050 A =  USR (0) INPUT  RUN : REM ATIVA LEITURA FLUIDA DO TECLADO
64060  REM CONFIGURA VIDEO
64095  RETURN 
64100  REM ** CARREGA DADOS EM MEMORIA
64110  RESTORE 64200
64120  READ E: REM ENDERECO DE INICIO DO BLOCO
64130  READ B: IF B >  = 0 THEN  POKE E,B:E = E + 1: GOTO 64130
64140  ON  ABS (B) GOTO 64120,64150: PRINT "ERRO:";B;"EM";E: END 
64150  RETURN 
