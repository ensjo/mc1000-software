1000  REM ** DESENHA RAIOS DE SOL
1010  FOR I = 1 TO 80
1020  PLOT 127,95 TO  RND (1) * 256, RND (1) * 96: REM DESENHA LINHA DO CENTRO DA TELA A UM PONTO ALEATORIO ACIMA
1030  NEXT I
1040  RETURN 
2000  REM ** DESENHA SOLO EM PERSPECTIVA
2010 IY = 96: REM COORDENADA Y NO HORIZONTE
2010  FOR I = 0 TO 255 STEP 8: REM COORDENADA X NO HORIZONTE
2030 JY = 191: REM COORDENADA Y NA BASE DA TELA
2040 J = 127 + (I - 127) * 4: REM COORDENADA X NA BASE DA TELA
2050  GOSUB 2100: REM CORTA LINHA DO SOLO QUE ATRAVESSA A MARGEM DA TELA
2060  PLOT I,IY TO J,JY: REM DESENHA LINHA
2070  NEXT I
2080  RETURN 
2100  REM ** CORTA LINHA DO SOLO QUE CRUZA A MARGEM DA TELA
2110  IF J < 0 THEN JY = 96 + 95 * I / (I - J):J = 0: RETURN : REM CORTA LINHA QUE CRUZA A MARGEM A ESQUERDA
2120  IF J >  = 256 THEN JY = 96 + 95 * (I - 256) / (I - J):J = 255: RETURN : REM CORTA LINHA QUE CRUZA A MARGEM A DIREITA
2130  RETURN 
64000  REM *** INICIALIZA MC-1000
64010  HGR : REM MODO GRAFICO 256X192,2 CORES
64020 X =  RND ( -  PEEK (264) * 256 -  PEEK (263) - .5): REM RANDOMIZE
64030  RETURN 
