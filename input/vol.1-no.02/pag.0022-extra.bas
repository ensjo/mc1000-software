1  CLEAR 512,16127: REM RESERVA RAM ALTA PARA ROTINA EM CODIGO DE MAQUINA
2  GOTO 100
3  REM *** ROTINAS UTILITARIAS MC-1000
4  REM ** SOUND R,V : ATRIBUI O VALOR V AO REGISTRADOR R DO AY-3-8910
5  IF R = 7 THEN V = 64 + (V AND 63): REM PROTEGE CONFIGURACAO DAS PORTAS IOA E IOB PARA LEITURA DE TECLADO
6 A =  USR ((R AND 15) * 256 + (V AND 255)): RETURN 
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 64000: REM INICIALIZA MC-1000
120  GOSUB 1000: REM EMITE EFEITO SONORO
130  END 
1000  REM *** EMITE EFEITO SONORO
1010  REM ATIVA E CONFIGURA CANAL A
1020 R = 7:V = 62: GOSUB 5: REM ATIVA CANAL A NO MIXER
1030 R = 8:V = 15: GOSUB 5: REM CANAL A NO VOLUME MAXIMO
1100  REM VARIA FREQUENCIA DO CANAL A
1110 R = 0
1120  FOR V = 255 TO 0 STEP  - 1
1130  GOSUB 5: REM DEFINE FREQUENCIA DO CANAL A
1140  NEXT V
1200  REM DESATIVA CANAL A
1210 R = 7:V = 63: GOSUB 5: REM DESATIVA CANAL A NO MIXER
1220  RETURN 
64000  REM *** INICIALIZA MC-1000
64010  GOSUB 64100: REM CARREGA ROTINA EM CODIGO DE MAQUINA
64020  CALL 16128: REM INICIALIZA ROTINA (INIT)
64030  RETURN 
64100  REM ** CARREGA DADOS EM MEMORIA
64110  RESTORE 64200
64120  READ E: REM ENDERECO DE INICIO DO BLOCO
64130  READ B: IF B >  = 0 THEN  POKE E,B:E = E + 1: GOTO 64130
64140  ON  ABS (B) GOTO 64120,64150: PRINT "ERRO:";B;"EM";E: END 
64150  RETURN 
64200  REM ** DADOS A CARREGAR NA MEMORIA
64210  REM DEFUSR=16128
64220  DATA 771        : REM ORG $0303
64230  DATA 195,0,63   : REM JP $3F00 ;MYSND
64240  DATA -1: REM FIM DE BLOCO
64300  REM ROTINA EM LINGUAGEM DE MAQUINA
64310  DATA 16128      : REM ORG $3F00
64320  REM INIT:
64030  REM ;BLOQUEIA INTERRUPCAO PADRAO
64040  DATA 33,175,197 : REM LD HL,$C5AF ;ENDERECO DE INSTRUCAO RETI
64050  DATA 34,57,0    : REM LD (#0039),HL
64060  DATA 201        : REM RET
64070  REM MYSND:
64080  REM ;ESCREVE VALOR EM REGISTRADOR DO AY-3-8910
64090  DATA 205,240,222: REM CALL $DEF0 ;DE=ARGUMENTO DE USR()
64100  REM ;D = REGISTRADOR, E = VALOR
64110  DATA 122        : REM LD A,D
64120  DATA 211,32     : REM OUT (REG),A ;SELECIONA REGISTRADOR
64130  DATA 123        : REM LD A,E
64140  DATA 211,96     : REM OUT (WR),A ;ESCREVE VALOR
64150  DATA 201        : REM RET
64160  DATA -2: REM FIM DE DADOS
