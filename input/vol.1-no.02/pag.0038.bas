2  REM *** ROTINAS UTILITARIAS MC-1000
3  REM ** LOCATE H,V : POSICIONA CURSOR
4  POKE 910,0: PRINT AT$; CHR$ (V); CHR$ (H + 32);: POKE 910,H AND 31: RETURN 
5  REM ** A$=INPUT$(1) : AGUARDA UMA TECLA
6  CALL 49158:A$ =  CHR$ ( PEEK (283)): RETURN 
100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 60000: REM INICIALIZA MC-1000
120  REM LACO PRINCIPAL
130  GOSUB 1000: REM INTRODUCAO
140  GOSUB 2000: REM ENTRADA
150  GOSUB 3000: REM CONVERTE
160  GOSUB 4000: REM EXIBE RESULTADO
170  GOSUB 5000: REM PERGUNTA SE CONTINUA
180  GOTO 130
1000  REM ** INICIALIZA PROGRAMA
1010  TEXT : HOME 
1020  PRINT "CONVERSAO DE DECIMAL P/ BINARIO"
1030  RETURN 
2000  REM ** ENTRADA
2010  PRINT : INPUT "DIGITE UM NUMERO ENTRE 0 E 1";N
2020  IF N <  = 0 OR N >  = 1 THEN 110: REM REJEITA NUMERO INVALIDO
2030  RETURN 
3000  REM ** CONVERTE NUMERO PARA BINARIO
3010 N$ = "0.": REM INICIALIZA RESULTADO
3020  FOR T = 1 TO 30: REM 30 DIGITOS BINARIOS
3030 N = N * 2: REM MULTIPLICA POR 2
3040 N$ = N$ +  CHR$ (48 +  INT (N)): REM CONCATENA "0" OU "1"
3050 N = N -  INT (N): REM REMOVE PARTE INTEIRA
3060  NEXT T
3070  RETURN 
4000  REM ** EXIBE RESULTADO
4010 H = 0:V = 8: GOSUB 4: PRINT "O NUMERO BINARIO E:"
4020  PRINT : PRINT N$: PRINT 
4030  RETURN 
5000  REM ** PERGUNTA SE CONTINUA
5010  PRINT "OUTRO NUMERO (S/N)?"
5020  GOSUB 6: REM A$=INPUT$(1)
5030  IF A$ = "S" THEN  RETURN : REM CONTINUA
5040  IF A$ = "N" THEN  END : REM TERMINA
5050  GOTO 5020
60000  REM *** INICIALIZA MC-1000
60010  REM CONSTANTES
60020 AT$ =  CHR$ (27) + "=": REM ESCAPE P/ POSICIONAR CURSOR
60030  RETURN 
