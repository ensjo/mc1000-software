100  REM *** PROGRAMA PRINCIPAL
110  GOSUB 9000: REM INICIALIZA
120  GOSUB 1000: REM ENTRADA
130  GOSUB 2000: REM CONVERTE ENTRADAS DA BASE
140  GOSUB 3000: REM REALIZA OPERACAO
150  GOSUB 4000: REM CONVERTE RESULTADO PARA BASE
160  GOSUB 5000: REM EXIBE RESULTADO
170  END 
1000  REM ** ENTRADA
1010  INPUT "BASE (ATE 36)";B
1020  INPUT "NUMERO (INTEIRO)";A$
1030  INPUT "SINAL (+,-,*,/)";S$
1040  INPUT "NUMERO (INTEIRO)";B$
1050  RETURN 
2000  REM ** CONVERTE ENTRADAS
2010 P$ = A$: GOSUB 6000: REM CONVERTE A$
2020 X$ =  STR$ (DE)
2030 P$ = B$: GOSUB 6000: REM CONVERTE B$
2040 Y$ =  STR$ (DE)
2050  RETURN 
3000  REM ** REALIZA OPERACAO
3010  IF S$ = "*" THEN X =  VAL (X$) *  VAL (Y$)
3020  IF S$ = "/" THEN X =  VAL (X$) /  VAL (Y$)
3030  IF S$ = "+" THEN X =  VAL (X$) +  VAL (Y$)
3040  IF S$ = "-" THEN X =  VAL (X$) -  VAL (Y$)
3050  RETURN 
4000  REM ** CONVERTE RESULTADO PARA A BASE
4010  REM REJEITA RESULTADO NAO INTEIRO
4020  IF X <  >  INT (X) THEN N$ = "RESULTADO NAO INTEIRO": RETURN 
4030  REM CONVERTE
4040 N$ = "": REM INICIALIZA STRING RESULTADO
4050 U = B *  INT (X / B)
4060  IF X - U > 9 THEN N$ =  CHR$ (55 + (X - U)) + N$: GOTO 4080
4070 N$ =  MID$ ( STR$ (X - U) + N$,2)
4080 X =  INT (X / B)
4080  IF X > 0 THEN  GOTO 4050
4090  RETURN 
5000  REM ** EXIBE RESULTADO
5010  PRINT A$;" ";S$;" ";B$;" = ";N$
5020  RETURN 
6000  REM ** CONVERTE NUMERO DA BASE
6010 DE = 0: REM VALOR DECIMAL
6020 IN = 0: REM INDICE (POTENCIA)
6030 Y =  ASC ( RIGHT$ (P$,1)): REM DIGITO MAIS A DIREITA
6040  IF Y < 58 THEN D = Y - 48: GOTO 6060: REM VALOR DO DIGITO 0-9
6050 D = Y - 55: REM VALOR DO DIGITO A-Z (10-35)
6060 DE = DE + D * B ^ IN: REM ACUMULA VALOR RELATIVO
6070 P$ =  LEFT$ (P$, LEN (P$) - 1): REM REMOVE DIGITO PROCESSADO
6080 IN = IN + 1: REM INCREMENTA POTENCIA
6090  IF  LEN (P$) > 0 THEN  GOTO 6030: REM CONTINUA SE AINDA HA DIGITOS
6100  RETURN 
